# Cariockko Environment Variables
# For local development with Docker Compose

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_CHAT=gpt-4o-mini
# STT/TTS models are hardcoded in agent code (gpt-4o-mini-transcribe / gpt-4o-mini-tts / voice: marin)
# OPENAI_MODEL_TRANSCRIPTION=gpt-4o-mini-transcribe
# OPENAI_MODEL_TTS=gpt-4o-mini-tts

# PostgreSQL
POSTGRES_DB=postgres
POSTGRES_PASSWORD=local-dev-password

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# API
DATABASE_URL=postgresql://postgres:local-dev-password@db:5432/postgres
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BUCKET=audio

# Web
# Client-side fetches use same-origin relative paths (proxied via Next.js
# rewrites — see web/next.config.ts). NEXT_PUBLIC_API_URL is kept for
# backwards compat with older builds.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Used by Next.js (server-side) to proxy /api/* and /audio/* to the
# backend services. Inside docker-compose these resolve to the service
# names; for local `next dev` they default to localhost.
# API_INTERNAL_URL=http://api:3001
# MINIO_INTERNAL_URL=http://minio:9000
